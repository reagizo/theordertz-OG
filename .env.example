# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# When deploying to production, set these to your PostgreSQL connection string.
# For local development, the app falls back to file-based JSON storage.
DATABASE_URL=postgresql://user:password@localhost:5432/theordertz

# ── Supabase ───────────────────────────────────────────────────────────────────
# Supabase project URL and keys for database and authentication (legacy - migrating to Firebase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Firebase ───────────────────────────────────────────────────────────────────
# Firebase project configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_FIREBASE_VAPID_KEY=your-firebase-vapid-key

# ── Authentication ────────────────────────────────────────────────────────────
# Session secret for signing cookies (min 32 characters)
SESSION_SECRET=change-this-to-a-random-32-char-string-in-production

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=The Order-Reagizo Service Company
APP_URL=https://your-domain.com

# ── Admin ─────────────────────────────────────────────────────────────────────
# Default admin credentials (change immediately after first login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=2097152

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
