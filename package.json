{
  "name": "theordertz",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "node dist/server/server.js",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "push": "git add . && git commit -m \"auto-deploy\" && git push",
    "watch": "onchange \"src/**/*\" -- npm run push",
    "cf-typegen": "wrangler types",
    "build:capacitor": "vite build --config vite.capacitor.config.ts",
    "build:mobile": "npm run build:capacitor && npx cap sync",
    "cap:sync": "npm run build:mobile",
    "cap:android": "npm run build:mobile && npx cap open android",
    "cap:ios": "npm run build:mobile && npx cap open ios",
    "cap:live": "npm run build:mobile && npx cap run"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@capacitor/ios": "^7.6.1",
    "@supabase/supabase-js": "^2.102.1",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-start": "^1.167.16",
    "@tanstack/react-store": "^0.9.3",
    "@tanstack/router-plugin": "^1.167.12",
    "@tanstack/store": "^0.9.3",
    "@vitejs/plugin-react": "^5.0.4",
    "chart.js": "^4.5.1",
    "dotenv": "^17.4.1",
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.6",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^6.0.2",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@cloudflare/vite-plugin": "^1.31.0",
    "@tailwindcss/vite": "^4.0.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.576.0",
    "onchange": "^7.1.0",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "supabase": "^2.87.2",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "wrangler": "^4.80.0"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.12",
    "h3": "2.0.1-rc.20",
    "h3-v2": "npm:h3@2.0.1-rc.20",
    "minimatch": "3.1.4",
    "serialize-javascript": "7.0.5",
    "tar": "7.5.13"
  }
}
